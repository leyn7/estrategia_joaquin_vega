# Copiar a /opt/mdt_bot/.env y completar (vacio = el bot corre pero solo loguea)
MDT_TG_TOKEN=
# Opcional: fijar el chat autorizado; si se deja vacio, el bot adopta el
# primer chat que le escriba (/start) y lo persiste en estado_vivo.json
MDT_TG_CHAT=
# Opcional: segundos entre escaneos (default 300)
MDT_INTERVALO=300

# Ejecucion real (Testnet) — regla usuario 14 jul.
# 'observacion' (default) = como hasta ahora, sin tocar ordenes.
# 'testnet' = coloca ordenes reales en Binance Futures TESTNET (dinero ficticio).
MDT_MODO=observacion
MDT_BALANCE_INICIAL=1000
MDT_RIESGO_PCT=0.01
# Generar en https://testnet.binancefuture.com/ (login con GitHub) -> API Key
MDT_BINANCE_TESTNET_KEY=
MDT_BINANCE_TESTNET_SECRET=
